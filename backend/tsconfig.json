{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": [
      "ES2020"
    ],
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "paths": {
      "@/services/*": [
        "./src/services/*"
      ],
      "@/routes/*": [
        "./src/routes/*"
      ],
      "@/config/*": [
        "./src/config/*"
      ],
      "@/middleware/*": [
        "./src/middleware/*"
      ],
      "@/db/*": [
        "./src/db/*"
      ]
    }
  },
  "include": [
    "src/**/*"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "src/db/seeds"
  ]
}
