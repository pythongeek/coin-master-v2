{
  "name": "cryptoflip-backend",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "nodemon --exec ts-node src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "lint": "eslint src/**/*.ts",
    "test": "ts-node src/test/run-all.ts",
    "test:ci": "ts-node src/test/run-all.ts",
    "test:integration": "ts-node src/test/run-all.ts",
    "migrate": "node-pg-migrate up --no-check-order --migrations-dir migrations",
    "migrate:down": "node-pg-migrate down --migrations-dir migrations",
    "migrate:create": "node-pg-migrate create --migrations-dir migrations",
    "price:sync": "npx ts-node src/jobs/price-sync.ts",
    "deposit:monitor": "npx ts-node src/jobs/deposit-monitor.ts",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1094.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@prisma/client": "5.22.0",
    "@sentry/node": "^10.64.0",
    "@solana/web3.js": "1.98.4",
    "@types/nodemailer": "^8.0.1",
    "@types/qrcode": "^1.5.6",
    "bcryptjs": "2.4.3",
    "bip39": "3.1.0",
    "bullmq": "5.79.1",
    "commander": "^14.0.3",
    "cors": "2.8.5",
    "decimal.js": "^10.5.0",
    "dotenv": "16.6.1",
    "ed25519-hd-key": "1.3.0",
    "ethers": "6.17.0",
    "eventsource": "^4.1.0",
    "express": "4.22.2",
    "express-rate-limit": "7.5.1",
    "geoip-lite": "2.0.3",
    "helmet": "8.2.0",
    "ioredis": "5.11.1",
    "jsonwebtoken": "9.0.3",
    "maxmind": "^4.3.4",
    "node-pg-migrate": "^8.0.4",
    "nodemailer": "^9.0.3",
    "pg": "8.22.0",
    "prisma": "5.22.0",
    "prom-client": "^15.1.3",
    "qrcode": "^1.5.4",
    "sharp": "^0.35.3",
    "socket.io": "4.8.3",
    "socket.io-client": "4.8.3",
    "swagger-ui-express": "^5.0.1",
    "tesseract.js": "^7.0.0",
    "tronweb": "6.4.0",
    "tweetnacl": "^1.0.3",
    "uuid": "^14.0.1",
    "winston": "^3.17.0",
    "winston-daily-rotate-file": "^5.0.0",
    "zod": "4.4.3"
  },
  "overrides": {
    "axios": "1.18.1",
    "ws": "^8.17.1",
    "jayson": "^4.2.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/geoip-lite": "^1.4.4",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.7.5",
    "@types/pg": "^8.11.10",
    "@types/swagger-ui-express": "^4.1.8",
    "@types/uuid": "^10.0.0",
    "nodemon": "^3.1.7",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.3"
  }
}
