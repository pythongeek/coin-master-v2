# ═══════════════════════════════════════════════════════════════
#  GIT IGNORE — এই ফাইলগুলো GitHub-এ আপলোড হবে না
# ═══════════════════════════════════════════════════════════════

# ── গোপন তথ্য (সবচেয়ে গুরুত্বপূর্ণ!) ─────────────────────────
.env
.env.local
.env.production
.env.*.local
*.pem
*.key
backend/src/config/secrets.ts

# ── SSH keys / sensitive downloads served via frontend ─────
# (Public/private keys placed under frontend/public/keys/ for
#  HTTPS download by the user. These are NOT for git.)
frontend/public/keys/*.key
frontend/public/keys/*.pem
frontend/public/keys/id_*
frontend/public/keys/cx23-access
frontend/public/keys/cx23-access.pub

# ── Env backups (may contain real API keys) ───────────────────
.env-backups/

# ── Dependencies ──────────────────────────────────────────────
node_modules/
.npm-global/
.pnp
.pnp.js

# ── Next.js Build ────────────────────────────────────────────
frontend/.next/
frontend/out/
frontend/build/
.next/

# ── Backend Build ─────────────────────────────────────────────
backend/dist/
backend/build/

# ── লগ ফাইল / রানটাইম ব্যাকআপ ───────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
backend/logs/
backend/backups/

# ── ডাটাবেস ───────────────────────────────────────────────────
*.sqlite
*.sqlite3
postgres_data/
redis_data/

# ── OS ফাইল ───────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── এডিটর ─────────────────────────────────────────────────────
.vscode/*
!.vscode/extensions.json
.idea/
*.swp
*.swo
*~

# ── টেস্টিং / কভারেজ ──────────────────────────
coverage/
.nyc_output/

# ── TypeScript ────────────────────────────────────────────────
*.tsbuildinfo
next-env.d.ts

# ── Docker ────────────────────────────────────────────────────
docker-compose.override.yml

# ── SSL সার্টিফিকেট ───────────────────────────
nginx/ssl/
*.crt
*.csr

# ── Hidden admin URL / gateway token (rotate with scripts) ──
.admin-secret-path
.admin-gateway-token
.admin-gateway.env

# ── Local env files created by wrapper scripts ──
.env.admin
*.env.local

# ── Misc runtime state ──
backend/exports/
backend/uploads/
frontend/public/uploads/

# ── Temporary / local scripts ──
fix_*.py
*_monitor.sh
*_cron.txt

# ── SSH keys and credentials (never commit!) ──
*_id_ed25519
*_id_ed25519.b64
id_ed25519
id_ed25519.b64
*.pub
VPS_CREDENTIALS.txt
SSH_CONNECTION.md

# ── Assessment / audit reports (local only) ──
*-assessment.md
*-audit-report.md

# ── Misc archives ──
*.zip

# ── MaxMind GeoIP2 .mmdb (P3-4b) ──
# The MaxMind GeoLite2 license permits free download but does not
# allow redistribution. Operators run scripts/download-geoip.sh
# to populate this directory at deploy time. Keep the README +
# .gitkeep so the directory ships with the repo.
geoip/*.mmdb
geoip/*.tar.gz
geoip/*.zip
