# CryptoFlip Environment

# ═══════════════════════════════════════════════════════════════
# SECURITY (mandatory in production)
# ═══════════════════════════════════════════════════════════════
# 32+ character random string. Never use a default/fallback value.
JWT_SECRET=your_random_32_char_minimum_secret_here_change_me

# MANDATORY: Admin 2FA enforcement.
#   true  = all admin accounts MUST have 2FA enabled (production default)
#   false = admins can log in without 2FA (dev/testing ONLY)
# The backend will REFUSE TO START if this is not set explicitly.
ADMIN_2FA_REQUIRED=true

# Issued by the upstream proxy (nginx/Cloudflare) to protect the admin path.
# Frontend middleware will reject admin requests when this is missing or wrong.
ADMIN_GATEWAY_TOKEN=generate_a_strong_random_token

# Optional: space-separated CIDR/IP allowlist for admin access.
# If set, admin requests must come from one of these IPs.
# Example: 127.0.0.1/32 10.0.0.0/8 203.0.113.45
ADMIN_IP_ALLOWLIST=

# ═══════════════════════════════════════════════════════════════
# DATABASE
# ═══════════════════════════════════════════════════════════════
DATABASE_URL=postgresql://user:password@postgres:5432/cryptoflip

# ═══════════════════════════════════════════════════════════════
# REDIS  (internal-only, no host port mapping in production)
# ═══════════════════════════════════════════════════════════════
# Redis is NOT exposed on the host. Only the backend container can
# reach it via the Docker network (redis:6379). Password is required.
# For debugging from the host: docker exec -it <redis-container> redis-cli -a <password>
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=generate_a_strong_random_redis_password
# REDIS_DB=0

# Optional: enable TLS for external managed Redis (AWS ElastiCache, Redis Cloud, etc.)
# When using Docker Compose internal Redis, leave this false.
REDIS_TLS_ENABLED=false

# ═══════════════════════════════════════════════════════════════
# BLOCKCHAIN
# ═══════════════════════════════════════════════════════════════
# Your mnemonic for deriving user deposit wallets. Keep encrypted.
WALLET_MNEMONIC=abandon abandon abandon abandon abandon abandon abandon abandon abandon abandon abandon about

# EVM RPC endpoints
ETHEREUM_RPC_URL=https://mainnet.infura.io/v3/YOUR_KEY
BSC_RPC_URL=https://bsc-dataseed.binance.org

# Solana RPC endpoint
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# Tron RPC endpoint
TRON_RPC_URL=https://api.trongrid.io

# ═══════════════════════════════════════════════════════════════
# CORS / CSRF
# ═══════════════════════════════════════════════════════════════
APP_URL=http://localhost:3000
TUNNEL_APP_URL=
CORS_ORIGIN=http://localhost:3000

# ═══════════════════════════════════════════════════════════════
# EMAIL / NOTIFICATIONS (optional)
# ═══════════════════════════════════════════════════════════════
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# ═══════════════════════════════════════════════════════════════
# S3-COMPATIBLE STORAGE (optional, for audit log backups)
# ═══════════════════════════════════════════════════════════════
S3_ENDPOINT=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=
S3_REGION=

# ═══════════════════════════════════════════════════════════════
# INTERNAL
# ═══════════════════════════════════════════════════════════════
# Used by the Next.js frontend API proxy to reach the backend container.
INTERNAL_API_URL=http://backend:4000

# Frontend public URL (used by browser bundle on localhost only).
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_SOCKET_URL=http://localhost:4000

# ═══════════════════════════════════════════════════════════════
# ADMIN CONFIG
# ═══════════════════════════════════════════════════════════════
# The secret path prefix for the admin panel. Should be random and unguessable.
ADMIN_SECRET_PATH=sysop-Ifj8Q52oDnAWxvAm

