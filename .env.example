# ===================================
# CryptoFlip — Environment Variables
# ===================================
# এই ফাইলটি কপি করে .env নামে সেভ করুন
# cp .env.example .env

# --- DATABASE (PostgreSQL) ---
POSTGRES_USER=cryptoflip_user
POSTGRES_PASSWORD=your_strong_password_here
POSTGRES_DB=cryptoflip_db
POSTGRES_PORT=5432
DATABASE_URL=postgresql://cryptoflip_user:your_strong_password_here@localhost:5432/cryptoflip_db

# --- CACHE (Redis) ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password_here

# --- BACKEND SERVER ---
NODE_ENV=development
BACKEND_PORT=4000
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production

# --- FRONTEND ---
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_SOCKET_URL=http://localhost:4000
NEXT_PUBLIC_APP_NAME=CryptoFlip

# --- GAME CONFIG ---
HOUSE_EDGE_PERCENT=2
MAX_BET_AMOUNT=1000
MIN_BET_AMOUNT=0.01
CRYPTO_RAIN_BUDGET_DAILY=50

# --- ADMIN ---
ADMIN_SECRET_KEY=your_admin_secret_key_here

# --- PGADMIN (DB management UI) ---
PGADMIN_EMAIL=admin@cryptoflip.com
PGADMIN_PASSWORD=admin_password_here

# --- DEPOSIT MONITOR (USDT Configuration) ---
USDT_CONTRACT_EVM=0xdAC17F958D2ee523a2206206994597C13D831ec7
USDT_MINT_SOLANA=Es9vMFrzaCERmJfrF4H2FYD4KCoNkY11McCe8BenwNYB
RPC_URL_EVM=https://eth.llamarpc.com
RPC_URL_SOLANA=https://api.mainnet-beta.solana.com

# --- MULTI-CHAIN STABLECOINS ---
USDC_CONTRACT_EVM=0xA0b86991c6218b36c1d19D4a2e9Eb0cE3606eB48
USDC_MINT_SOLANA=EPjFWdd5AufqSSqeM2qN1xzybapC8G4wEGGkZwyTDt1v
USDT_CONTRACT_TRON=TR7NHqjeKQxGTCi8q8ZY4pL8otSzgjLj6t
